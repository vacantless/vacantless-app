# Copy to .env.local and fill in from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Supabase → Project Settings → API → service_role (KEEP SECRET, never expose to the browser).
# Used only by the RLS verification script (scripts/verify-rls.mjs), never in app runtime.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
